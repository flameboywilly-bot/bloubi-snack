<script>
'use strict';
const COLS=['#00e5ff','#00ff9d','#ff6b35','#ff2d55','#ffd60a','#c77dff','#ff9af5','#4cc9f0','#ffffff','#aaffc3','#ffb347','#7bed9f'];
const FACES=['😀','😎','🤩','😈','👾','🐸','🤖','🦊','🐉','💀','🔥','⚡','🎯','🌟','🍀'];
const BNAMES=['Zephyr','Nova','Kira','Blaze','Echo','Volt','Lyra','Drex','Fang','Mira','Orion','Axel','Ravi','Sora','Dusk','Neon','Pixel','Glitch'];
const ITEMS=[
  {id:'crown',name:'Couronne royale',icon:'👑',price:150},{id:'halo',name:'Halo doré',icon:'😇',price:100},
  {id:'star',name:'Étoile filante',icon:'⭐',price:50},{id:'rainbow',name:'Arc-en-ciel',icon:'🌈',price:120},
  {id:'flame',name:'Flammes',icon:'🔥',price:75},{id:'lightning',name:'Éclairs',icon:'⚡',price:60},
  {id:'diamond',name:'Diamant VIP',icon:'💎',price:150},{id:'music',name:'Notes musicales',icon:'🎵',price:40},
  {id:'alien',name:'Visage alien',icon:'👽',price:90},{id:'ninja',name:'Masque ninja',icon:'🥷',price:110},
  {id:'party',name:'Chapeau de fête',icon:'🎉',price:35},{id:'sunglasses',name:'Lunettes cool',icon:'🕶️',price:65}
];
const DCFG={easy:{spd:105,react:.7,cnt:8,lbl:'8 bots lents et prévisibles'},normal:{spd:132,react:.35,cnt:12,lbl:'12 bots de difficulté variée'},hard:{spd:168,react:.12,cnt:16,lbl:'16 bots rapides et agressifs'}};
const SRVS=[{n:'Europe — Paris 🇫🇷',ping:12,p:47,m:100},{n:'Europe — Frankfurt 🇩🇪',ping:28,p:31,m:100},{n:'Amérique — NY 🇺🇸',ping:95,p:62,m:100},{n:'Asie — Tokyo 🗼',ping:180,p:88,m:100},{n:'Océanie — Sydney 🦘',ping:240,p:19,m:100}];
const MAP=3200,CELL=18,MAX_ORBS=260,ORB_INT=8,COIN_INT=300,COIN_R=15,REV_COST=2500,SDRN=28,SREG=14;
const SEC={
  hash(s){let h=5381;for(let i=0;i<s.length;i++)h=((h<<5)+h)^s.charCodeAt(i);return(h>>>0).toString(36)},
  san(s){return String(s).replace(/[<>"'&]/g,'').trim().slice(0,32)},
  vname(n){if(!n||n.length<2||n.length>16)return'Pseudo : 2–16 caractères';if(!/^[a-zA-Z0-9_\-éèàùâêîôûçœæ ]+$/.test(n))return'Caractères invalides';return null},
  vpass(p){if(!p||p.length<4)return'Mot de passe : min 4 caractères';return null},
  _atm:{},
  rate(k){const n=Date.now();if(!this._atm[k])this._atm[k]=[];this._atm[k]=this._atm[k].filter(t=>n-t<60000);if(this._atm[k].length>=5)return false;this._atm[k].push(n);return true},
  cn(v,a,b){return Math.max(a,Math.min(b,Number(v)||0))}
};
// ── STORAGE ENGINE v3 (robuste, versionné, avec backup) ──
const STORE = {
  K_DB:'bloubi_db_v3', K_SES:'bloubi_ses_v3', K_SET:'bloubi_set_v3', K_BAK:'bloubi_bak_v3', VER:3,
  save(db){
    try{
      const cur=localStorage.getItem(this.K_DB);
      if(cur)localStorage.setItem(this.K_BAK,cur); // backup avant écrasement
      localStorage.setItem(this.K_DB,JSON.stringify({v:this.VER,ts:Date.now(),d:db}));
      return true;
    }catch(e){console.error('[STORE.save]',e);return false;}
  },
  load(){
    // Essaie clé principale, sinon backup, sinon objet vide
    for(const k of[this.K_DB,this.K_BAK]){
      try{
        const raw=localStorage.getItem(k);
        if(!raw)continue;
        const p=JSON.parse(raw);
        if(p&&p.d&&typeof p.d==='object')return this._migrate(p.d);
      }catch(e){console.warn('[STORE.load] clé',k,'corrompue, essai backup');}
    }
    return {};
  },
  _migrate(db){
    // Migration depuis anciennes versions (bs2, bs_accounts, bs_db)
    if(!Object.keys(db).length){
      for(const oldKey of['bs2','bs_accounts','bs_db']){
        try{
          const raw=localStorage.getItem(oldKey);
          if(!raw)continue;
          const p=JSON.parse(raw);
          const src=p.data||p.d||p;
          if(src&&typeof src==='object'&&Object.keys(src).length){
            console.log('[STORE] migration depuis',oldKey);
            Object.assign(db,src);
          }
        }catch{}
      }
    }
    return db;
  },
  saveSession(key){try{localStorage.setItem(this.K_SES,key);}catch{}},
  loadSession(){try{return localStorage.getItem(this.K_SES)||null;}catch{return null;}},
  clearSession(){try{localStorage.removeItem(this.K_SES);}catch{}},
  saveSettings(s){try{localStorage.setItem(this.K_SET,JSON.stringify(s));}catch{}},
  loadSettings(){try{const r=localStorage.getItem(this.K_SET);return r?JSON.parse(r):{};}catch{return{};}}
};
 
function defP(u){return{username:u,ph:'',coins:0,score:0,ws:0,ts:0,kills:0,games:0,skin:{color:COLS[0],face:'😀',acc:null},owned:[],v:3,createdAt:Date.now(),lastLogin:Date.now()}}
 
// Charge la DB au démarrage (fusion migration incluse)
let DB=STORE.load();
let CU=null;
let UST={names:true,mm:true,particles:true,zoom:1};
let pendBuy=null,gmode='solo',gdiff='normal',selSrv=0;
let P=null,ents=[],orbs=[],drop=[],parts=[];
let GC,GX,MMC,MCX,camX=0,camY=0,camZ=1,keys={},mX=0,mY=0;
let spE=100,gRunning=false,raf=null,lts=0;
let sKills=0,maxSz=0,gStart=0,revTgt=null,lkName='',lkObj=null;
// Sauvegarde complète et atomique du joueur courant
function su(){
  if(!CU)return;
  // Clamp toutes les valeurs numériques pour éviter la triche
  CU.coins=SEC.cn(CU.coins,0,9999999);
  CU.score=SEC.cn(CU.score,0,9999999);
  CU.ws=SEC.cn(CU.ws||0,0,9999999);
  CU.ts=SEC.cn(CU.ts||0,0,9999999);
  CU.kills=SEC.cn(CU.kills||0,0,9999999);
  CU.games=SEC.cn(CU.games||0,0,9999999);
  CU.lastSave=Date.now();
  // Toujours écrire avec la clé en minuscules pour cohérence
  DB[CU.username.toLowerCase()]=CU;
  STORE.save(DB);
}
function lust(){try{const s=STORE.loadSettings();UST={...UST,...s};}catch{}}
function sust(){try{STORE.saveSettings(UST);}catch{}}
function doReg(){
  const n=SEC.san(document.getElementById('rn').value.trim());
  const p=document.getElementById('rp').value;
  const p2=document.getElementById('rp2').value;
  const e=document.getElementById('re');
  e.textContent='';
  // Rate limiting
  if(!SEC.rate('reg')){e.textContent='Trop de tentatives, attends 1 minute';return;}
  // Validation pseudo
  const ne=SEC.vname(n);if(ne){e.textContent=ne;return;}
  // Validation mot de passe
  const pe=SEC.vpass(p);if(pe){e.textContent=pe;return;}
  if(p!==p2){e.textContent='Les mots de passe ne correspondent pas';return;}
  // Vérification nom unique (insensible à la casse)
  if(DB[n.toLowerCase()]){e.textContent='Ce pseudo est déjà pris, choisis-en un autre';return;}
  // Vérification aussi avec variantes accentuées
  const taken=Object.keys(DB).some(k=>k.toLowerCase()===n.toLowerCase());
  if(taken){e.textContent='Ce pseudo est déjà pris, choisis-en un autre';return;}
  // Créer le profil
  const pr=defP(n);
  pr.ph=SEC.hash(p+n.toLowerCase()); // hash salé avec le nom
  DB[n.toLowerCase()]=pr;
  const saved=STORE.save(DB);
  if(!saved){e.textContent='Erreur de sauvegarde, réessaie';return;}
  CU=pr;
  STORE.saveSession(n.toLowerCase());
  lust();openMenu();
}
function doLog(){
  const n=SEC.san(document.getElementById('ln').value.trim());
  const p=document.getElementById('lp').value;
  const e=document.getElementById('le');
  e.textContent='';
  if(!n||!p){e.textContent='Remplis tous les champs';return;}
  // Rate limiting par nom d'utilisateur
  if(!SEC.rate('log_'+n.toLowerCase())){e.textContent='Trop de tentatives, attends 1 minute';return;}
  // Recharge la DB depuis localStorage pour avoir les données les plus récentes
  DB=STORE.load();
  const pr=DB[n.toLowerCase()];
  if(!pr){e.textContent='Compte introuvable';return;}
  // Hash salé: hash(password + username)
  const expectedHash=SEC.hash(p+n.toLowerCase());
  // Compatibilité avec ancien hash non salé
  const legacyHash=SEC.hash(p);
  if(pr.ph!==expectedHash&&pr.ph!==legacyHash){e.textContent='Mot de passe incorrect';return;}
  // Mise à jour du hash vers la version salée si c'était l'ancien format
  if(pr.ph===legacyHash&&pr.ph!==expectedHash){pr.ph=expectedHash;}
  // Deep copy pour éviter les mutations non sauvegardées
  CU=JSON.parse(JSON.stringify(pr));
  CU.lastLogin=Date.now();
  su(); // sauvegarde immédiate
  STORE.saveSession(n.toLowerCase());
  lust();openMenu();
}
