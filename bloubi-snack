.card{background:linear-gradient(145deg,rgba(10,18,32,.97),rgba(13,24,40,.97));border:1px solid rgba(0,229,255,.13);border-radius:20px;padding:2.2rem 2.6rem;width:min(480px,94vw);box-shadow:0 0 60px rgba(0,0,0,.7),0 0 0 1px rgba(255,255,255,.025),inset 0 1px 0 rgba(255,255,255,.055);backdrop-filter:blur(16px)}
