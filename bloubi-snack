  for(let i=0;i<all.length;i++){
    const a=all[i];if(a.dead)continue;
    for(let j=0;j<all.length;j++){
      if(i===j)continue;const b=all[j];if(b.dead)continue;
      for(let si=3;si<b.segs.length;si++){
        if(dst(a.x,a.y,b.segs[si].x,b.segs[si].y)<a.sz*.85+b.sz*.55){
          if(a.isP){killP(b);return}else{killE(a,b);break}
        }
      }
    }
  }
}
function killE(dead,killer){
  if(dead.dead)return;dead.dead=true;dead.dt=0;dropO(dead);
  if(killer){killer.score+=Math.floor(dead.score*.5);killer.len+=dead.len*.15;killer.sz=csz(killer.len);kfeed(killer.name,dead.name);
    if(killer.isP){sKills++;document.getElementById('h-kl').textContent=sKills;if(UST.particles)spPart(dead.x,dead.y,dead.color,20)}}
}
function killP(killer){
  if(!P||P.dead)return;
  P.dead=true;gRunning=false;dropO(P);
  lkObj=killer;lkName=killer?killer.name:'Inconnu';revTgt=(!killer||killer.isP)?null:killer;
  if(CU){
    CU.score=Math.max(CU.score,P.score);
    CU.ws=SEC.cn((CU.ws||0)+P.score,0,9999999);
    CU.ts=SEC.cn((CU.ts||0)+P.score,0,9999999);
    CU.kills=SEC.cn((CU.kills||0)+sKills,0,9999999);
    CU.games=SEC.cn((CU.games||0)+1,0,9999999);
    su(); // sauvegarde immédiate à la mort
  }
  setTimeout(showDS,700);
}
function dropO(s){
  const cnt=clp(Math.floor(s.len*.8),5,80);const pal=[s.color,'#ffd60a','#00ff9d','#ff2d55'];
  for(let i=0;i<cnt;i++){const a=Math.random()*Math.PI*2,r=Math.random()*s.sz*3;drop.push({x:s.x+Math.cos(a)*r,y:s.y+Math.sin(a)*r,r:5+Math.random()*5,color:pal[Math.floor(Math.random()*pal.length)],val:2+Math.floor(Math.random()*3),ph:Math.random()*Math.PI*2,life:0})}
  if(UST.particles)spPart(s.x,s.y,s.color,30)
}
function rnd(){
  GX.clearRect(0,0,GC.width,GC.height);GX.save();GX.scale(camZ,camZ);GX.translate(-camX,-camY);
  drawBG();drawDrop();drawOrbs();if(UST.particles)drawParts();
  for(const e of ents)if(!e.dead)drawSnk(e);if(P&&!P.dead)drawSnk(P);drawBound();GX.restore();drawMM()
}
function drawBG(){
  GX.fillStyle='#04070d';GX.fillRect(camX,camY,GC.width/camZ,GC.height/camZ);
  GX.strokeStyle='rgba(0,229,255,.026)';GX.lineWidth=1;const gs=72;
  const sx=Math.floor(camX/gs)*gs,sy=Math.floor(camY/gs)*gs,ex=camX+GC.width/camZ+gs,ey=camY+GC.height/camZ+gs;
  for(let x=sx;x<ex;x+=gs){GX.beginPath();GX.moveTo(x,camY);GX.lineTo(x,ey);GX.stroke()}
  for(let y=sy;y<ey;y+=gs){GX.beginPath();GX.moveTo(camX,y);GX.lineTo(ex,y);GX.stroke()}
}
function drawBound(){
  GX.save();GX.strokeStyle='rgba(255,45,85,.65)';GX.lineWidth=8;GX.shadowColor='#ff2d55';GX.shadowBlur=18;
  GX.strokeRect(2,2,MAP-4,MAP-4);GX.restore()
}
function drawOrbs(){
  const t=performance.now()/1000;GX.save();
  for(const o of orbs){const p=.85+Math.sin(o.ph+t*2.5)*.15;GX.beginPath();GX.arc(o.x,o.y,o.r*p,0,Math.PI*2);GX.fillStyle=o.color;GX.shadowColor=o.color;GX.shadowBlur=13;GX.fill()}
  GX.restore()
}
function drawDrop(){
  const t=performance.now()/1000;GX.save();
  for(const o of drop){const p=.8+Math.sin(o.ph+t*5)*.2,fd=Math.min(1,(25-o.life)/5);GX.globalAlpha=fd;GX.beginPath();GX.arc(o.x,o.y,o.r*p,0,Math.PI*2);GX.fillStyle=o.color;GX.shadowColor=o.color;GX.shadowBlur=17;GX.fill();GX.beginPath();GX.arc(o.x,o.y,o.r*p+4,0,Math.PI*2);GX.strokeStyle=o.color+'44';GX.lineWidth=1.5;GX.stroke();GX.shadowBlur=0}
  GX.globalAlpha=1;GX.restore()
}
function drawSnk(s){
  if(!s.segs||!s.segs.length)return;
  const ws=s.isP&&(keys.ShiftLeft||keys.ShiftRight)&&spE>10;
  GX.save();
  for(let i=s.segs.length-1;i>=1;i--){
    const sg=s.segs[i],rt=i/s.segs.length,r=Math.max(4,s.sz*(.55+(1-rt)*.45));
    const g=GX.createRadialGradient(sg.x-r*.28,sg.y-r*.28,0,sg.x,sg.y,r);
    g.addColorStop(0,lh(s.color,.35));g.addColorStop(.6,s.color);g.addColorStop(1,lh(s.color,-.28));
    GX.beginPath();GX.arc(sg.x,sg.y,r,0,Math.PI*2);GX.fillStyle=g;
    if(ws&&i%3===0){GX.shadowColor=s.color;GX.shadowBlur=8}GX.fill();GX.shadowBlur=0
  }
  const hx=s.segs[0].x,hy=s.segs[0].y,hs=s.sz;
  GX.shadowColor=s.color;GX.shadowBlur=s.isP?22:11;
  const hg=GX.createRadialGradient(hx-hs*.3,hy-hs*.3,0,hx,hy,hs*1.1);
  hg.addColorStop(0,lh(s.color,.44));hg.addColorStop(.5,s.color);hg.addColorStop(1,lh(s.color,-.24));
  GX.beginPath();GX.arc(hx,hy,hs,0,Math.PI*2);GX.fillStyle=hg;GX.fill();GX.shadowBlur=0;
  // face CLIPPED to head
  GX.save();GX.beginPath();GX.arc(hx,hy,hs*1.04,0,Math.PI*2);GX.clip();
  GX.font=hs*1.15+'px serif';GX.textAlign='center';GX.textBaseline='middle';GX.fillText(s.face||'😀',hx,hy);GX.restore();
  // accessory above head (not clipped)
  const accIt=s.isP?(CU?.skin.acc?ITEMS.find(i=>i.id===CU.skin.acc):null):s.acc;
  if(accIt){GX.font=hs*.9+'px serif';GX.textAlign='center';GX.textBaseline='bottom';GX.fillText(accIt.icon,hx,hy-hs*1.08)}
  // name tag
  if(UST.names!==false){
    GX.save();const fn=Math.max(10,hs*.7);GX.font='bold '+fn+'px "Exo 2",sans-serif';GX.textAlign='center';GX.textBaseline='bottom';
    const ny=hy-hs-(accIt?hs*1.4:4),tw=GX.measureText(s.name).width;
    GX.fillStyle='rgba(0,0,0,.52)';GX.beginPath();GX.roundRect(hx-tw/2-4,ny-fn-2,tw+8,fn+5,4);GX.fill();
    GX.fillStyle=s.isP?'#fff':'rgba(215,238,255,.9)';GX.shadowColor='rgba(0,0,0,.75)';GX.shadowBlur=3;GX.fillText(s.name,hx,ny);GX.restore()
  }
  GX.restore()
}
function drawParts(){GX.save();for(const p of parts){GX.globalAlpha=p.life;GX.beginPath();GX.arc(p.x,p.y,p.sz,0,Math.PI*2);GX.fillStyle=p.color;GX.fill()}GX.globalAlpha=1;GX.restore()}
function spPart(x,y,c,n){for(let i=0;i<n;i++){const a=Math.random()*Math.PI*2,s=20+Math.random()*80;parts.push({x,y,vx:Math.cos(a)*s,vy:Math.sin(a)*s,sz:2+Math.random()*3,life:.8+Math.random()*.5,color:c})}}
function drawMM(){
  if(!UST.mm||!MCX)return;const mw=128,mh=128,sx=mw/MAP,sy=mh/MAP;
  MCX.fillStyle='rgba(4,7,13,.92)';MCX.fillRect(0,0,mw,mh);
  MCX.strokeStyle='rgba(255,45,85,.45)';MCX.lineWidth=1;MCX.strokeRect(0,0,mw,mh);
  for(const o of orbs){MCX.fillStyle=o.color+'77';MCX.fillRect(o.x*sx-.5,o.y*sy-.5,1.5,1.5)}
  for(const e of ents){if(e.dead)continue;MCX.fillStyle=e.color;MCX.beginPath();MCX.arc(e.x*sx,e.y*sy,2.5,0,Math.PI*2);MCX.fill()}
  if(P&&!P.dead){
    const vx=camX*sx,vy=camY*sy,vw=GC.width/camZ*sx,vh=GC.height/camZ*sy;
    MCX.strokeStyle='rgba(255,255,255,.18)';MCX.lineWidth=1;MCX.strokeRect(vx,vy,vw,vh);
    MCX.fillStyle='#fff';MCX.shadowColor='#fff';MCX.shadowBlur=6;
    MCX.beginPath();MCX.arc(P.x*sx,P.y*sy,3.5,0,Math.PI*2);MCX.fill();MCX.shadowBlur=0
  }
}
function updHUD(){if(!P)return;document.getElementById('h-sc').textContent=P.score.toLocaleString();document.getElementById('h-sz').textContent=Math.floor(P.len);document.getElementById('h-kl').textContent=sKills;document.getElementById('h-co').textContent=CU?.coins||0}
function updLB(){
  const lst=[{name:P.name,score:P.score,face:P.face,isP:true},...ents.filter(e=>!e.dead).map(e=>({name:e.name,score:e.score,face:e.face,isP:false}))].sort((a,b)=>b.score-a.score).slice(0,8);
  document.getElementById('hlbl').innerHTML=lst.map((e,i)=>`<div class="hr${e.isP?' me':''}"><div class="hp">${i+1}</div><div class="hemo">${e.face}</div><div class="hnam">${SEC.san(e.name)}</div><div class="hsc">${e.score}</div></div>`).join('')
}
function kfeed(k,v){const kf=document.getElementById('kf'),el=document.createElement('div');el.className='kfe';el.innerHTML=`<span class="ka">${SEC.san(k)}</span> <span style="color:var(--dim)">✂</span> <span class="kv">${SEC.san(v)}</span>`;kf.insertBefore(el,kf.firstChild);setTimeout(()=>el.remove(),4100);while(kf.children.length>5)kf.removeChild(kf.lastChild)}
function cpop(t){const el=document.createElement('div');el.className='cpp';el.style.cssText='left:'+(13+Math.random()*55)+'px;bottom:'+(85+Math.random()*30)+'px';el.textContent=t;document.body.appendChild(el);setTimeout(()=>el.remove(),2300)}
function showDS(){
  const el=Math.round((Date.now()-gStart)/1000),m=Math.floor(el/60),s=el%60;
  document.getElementById('dby').textContent=lkName?'Éliminé par '+SEC.san(lkName):'Mort mystérieuse';
  document.getElementById('dsc').textContent=(P?.score||0).toLocaleString();document.getElementById('dsz').textContent=maxSz;
  document.getElementById('dkl').textContent=sKills;document.getElementById('dtm').textContent=m>0?m+'m '+s+'s':s+'s';
  const can=revTgt&&!revTgt.dead&&(CU?.coins||0)>=REV_COST,rb=document.getElementById('rvb');
  rb.disabled=!can;rb.textContent=can?'⚔️ Vengeance sur '+SEC.san(revTgt.name)+' — '+REV_COST+'🪙':'⚔️ Vengeance — '+REV_COST+'🪙'+(revTgt&&(CU?.coins||0)<REV_COST?' (manque de pièces)':!revTgt?' (cible indisponible)':'');
  document.getElementById('ds').classList.add('show');gRunning=true
}
function doRevenge(){
  if(!revTgt||revTgt.dead||!CU||CU.coins<REV_COST)return;CU.coins-=REV_COST;su();document.getElementById('h-co').textContent=CU.coins;
  revTgt.len=Math.max(4,Math.floor(revTgt.len/2));revTgt.sz=csz(revTgt.len);while(revTgt.segs.length>Math.floor(revTgt.len))revTgt.segs.pop();revTgt.score=Math.floor(revTgt.score/2);
  kfeed('⚔️ VENGEANCE',revTgt.name);if(UST.particles)spPart(revTgt.x,revTgt.y,'#ff2d55',25);toast('⚔️ Vengeance exécutée sur '+SEC.san(revTgt.name)+' !');document.getElementById('rvb').disabled=true;revTgt=null
}
function replayG(){document.getElementById('ds').classList.remove('show');gRunning=false;setTimeout(()=>launch(gmode),80)}
function backMenu(){
  if(CU)su(); // sauvegarde avant de quitter
  gRunning=false;
  if(raf){cancelAnimationFrame(raf);raf=null;}
  clearInterval(window._ci);
  document.getElementById('ds').classList.remove('show');
  const gc=document.getElementById('game-canvas'),hud=document.getElementById('hud'),mm=document.getElementById('minimap');
  if(gc)gc.style.display='none';if(hud)hud.style.display='none';if(mm)mm.style.display='none';
  document.removeEventListener('keydown',kd);document.removeEventListener('keyup',ku);
  if(GC){GC.removeEventListener('mousemove',mm);GC.removeEventListener('touchmove',tm);}
  updBadge();ss('sc-menu');
}
function kd(e){
  keys[e.code]=true;
  if(['Space','ShiftLeft','ShiftRight','ArrowUp','ArrowDown'].includes(e.code))e.preventDefault();
  // TAB = retour au menu pendant la partie
  if(e.code==='Tab'){e.preventDefault();backMenu();}
  // Escape = retour au menu aussi
  if(e.code==='Escape'){e.preventDefault();backMenu();}
}
function ku(e){keys[e.code]=false}
function mm(e){mX=e.clientX;mY=e.clientY}
function mm2(e){mX=e.clientX;mY=e.clientY}
function tm(e){e.preventDefault();if(e.touches[0]){mX=e.touches[0].clientX;mY=e.touches[0].clientY}}
function dst(ax,ay,bx,by){return Math.hypot(ax-bx,ay-by)}
function clp(v,a,b){return Math.max(a,Math.min(b,v))}
function h2r(hex){let c=hex.replace('#','');if(c.length===3)c=c[0]+c[0]+c[1]+c[1]+c[2]+c[2];return[parseInt(c.slice(0,2),16),parseInt(c.slice(2,4),16),parseInt(c.slice(4,6),16)]}
function lh(hex,a){const[r,g,b]=h2r(hex);return'rgb('+(clp(r+a*255,0,255)|0)+','+(clp(g+a*255,0,255)|0)+','+(clp(b+a*255,0,255)|0)+')'}
window.addEventListener('resize',()=>{if(GC&&gRunning){GC.width=innerWidth;GC.height=innerHeight}const b=document.getElementById('bg-canvas');if(b){b.width=innerWidth;b.height=innerHeight}});
window.addEventListener('load',()=>{
  // Charge la DB avec migration automatique des anciennes versions
  DB=STORE.load();
  const ses=STORE.loadSession();
  if(ses&&DB[ses]){
    // Deep copy pour isolation
    CU=JSON.parse(JSON.stringify(DB[ses]));
    lust();openMenu();
  } else {
    ss('sc-reg');
  }
  // Auto-save toutes les 10 secondes (plus fréquent)
  setInterval(()=>{if(CU)su();},10000);
  // Sauvegarde aussi à la fermeture de la page
  window.addEventListener('beforeunload',()=>{if(CU)su();});
  window.addEventListener('visibilitychange',()=>{if(document.hidden&&CU)su();});
});
</script>
</body>
