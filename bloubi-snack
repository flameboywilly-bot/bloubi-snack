.mc .mci{font-size:2.4rem;margin-bottom:.55rem}.mc .mct{font-weight:800;font-size:1rem;margin-bottom:.28rem}.mc .mcd{font-size:.72rem;color:var(--dim);line-height:1.4}
.mcbdg{position:absolute;top:7px;right:7px;font-size:.58rem;padding:2px 6px;border-radius:4px;font-weight:700;text-transform:uppercase;letter-spacing:.04em}
